{
  "name": "Porn Site Blocker",
  "description": "A porn site blocker that helps users/ porn addicts avoid accessing explicit content online.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_icon": "icons.svg"
  },
   "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs","cookies"],
  "content_scripts": [
    { "matches": 
    ["http://*/*", "https://*/*"], "js": ["contentScript.js"], "all_frames":true,"run_at":"document_idle"}
  ]
}